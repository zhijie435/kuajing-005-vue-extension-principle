{
  "name": "crm/extension-manager",
  "description": "CRM扩展点管理后端API",
  "type": "project",
  "require": {
    "php": ">=8.1",
    "ext-pdo": "*",
    "ext-json": "*"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
    "serve": "php -S localhost:8000 -t api",
    "db:init": "php -r \"require 'api/index.php';\""
  }
}
